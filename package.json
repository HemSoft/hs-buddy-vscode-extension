{
  "name": "hs-buddy",
  "displayName": "HemSoft Buddy Extension",
  "description": "Productivity extension aiding the developer in working with GitHub Copilot.",
  "version": "0.1.0",
  "publisher": "HemSoft",
  "license": "MIT",
  "icon": "assets/hs-buddy-vscode-extension-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/HemSoft/hs-buddy-vscode-extension.git"
  },
  "homepage": "https://github.com/HemSoft/hs-buddy-vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/HemSoft/hs-buddy-vscode-extension/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Data Science",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "copilot",
    "github copilot",
    "productivity",
    "ai",
    "statistics",
    "session",
    "hemsoft"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "icons": {
      "hs-buddy-icon": {
        "description": "HemSoft Buddy icon",
        "default": {
          "fontPath": "assets/fonts/hs-buddy-icons.woff2",
          "fontCharacter": "\\EA01"
        }
      }
    },
    "commands": [
      {
        "command": "hs-buddy.showMenu",
        "title": "Copilot Sessions",
        "category": "HemSoft Buddy",
        "icon": "$(hs-buddy-icon)"
      },
      {
        "command": "hs-buddy.helloWorld",
        "title": "Hello World",
        "category": "HemSoft Buddy"
      }
    ],
    "configuration": {
      "title": "HemSoft Buddy",
      "properties": {
        "hsBuddy.scanIntervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "How often to scan for new Copilot sessions (in minutes)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:all": "npm run lint && npm run lint:md",
    "knip": "knip",
    "test": "vscode-test",
    "package": "vsce package",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.1",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1"
  }
}
