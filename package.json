{
  "name": "hs-buddy",
  "displayName": "HemSoft Buddy",
  "description": "A suite of productivity extensions for VS Code by HemSoft",
  "version": "0.1.0",
  "publisher": "HemSoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HemSoft/hs-buddy-vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hs-buddy.helloWorld",
        "title": "Hello World",
        "category": "HemSoft Buddy"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0"
  }
}
